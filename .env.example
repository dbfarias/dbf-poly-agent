# === Polymarket ===
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_PRIVATE_KEY=
POLY_CHAIN_ID=137

# === Trading ===
TRADING_MODE=paper
INITIAL_BANKROLL=5.0
SCAN_INTERVAL_SECONDS=60
SNAPSHOT_INTERVAL_SECONDS=300

# === Risk ===
MAX_DAILY_LOSS_PCT=0.10
MAX_DRAWDOWN_PCT=0.25
DAILY_TARGET_PCT=0.01

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///data/polybot.db

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# === Dashboard Auth ===
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=
FORCE_HTTPS_COOKIES=false

# === Telegram (optional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === LLM Sentiment (optional — only needed when use_llm_sentiment=true) ===
ANTHROPIC_API_KEY=

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json
